    {
      "name": "2. Checkout & WA Notification API",
      "item": [
        {
          "name": "Process Checkout (Forward WA Owner)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"ORD-TEST-001\",\n  \"userId\": \"trisna@example.com\",\n  \"userName\": \"Trisna Ibnu\",\n  \"name\": \"Trisna Ibnu M\",\n  \"phone\": \"081234567890\",\n  \"address\": \"Jl. Sudirman No. 123\",\n  \"destCity\": \"Bandung\",\n  \"items\": [\n    { \"id\": 1, \"name\": \"Kemeja Flannel Pria Kotak-Kotak\", \"price\": 135000, \"qty\": 2 },\n    { \"id\": 4, \"name\": \"Kaos Oversize Distro\", \"price\": 95000, \"qty\": 1 }\n  ],\n  \"subtotal\": 365000,\n  \"shippingCost\": 20000,\n  \"shippingLabel\": \"JNE Reguler (2-3 hari)\",\n  \"total\": 385000,\n  \"paymentMethod\": \"Transfer BCA\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/checkout",
              "host": ["{{base_url}}"],
              "path": ["api", "checkout"]
            },
            "description": "Endpoint ini akan menyimpan pesanan ke database MySQL dan mengirimkan pesan notifikasi WhatsApp secara otomatis ke nomor Owner/Admin yang diatur di variabel ADMIN_WA pada .env"
          }
        }
      ]
    },
