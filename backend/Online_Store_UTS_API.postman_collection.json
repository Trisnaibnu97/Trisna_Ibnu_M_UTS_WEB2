  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check & Welcome",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": [""]
        },
        "description": "Cek status backend API apakah aktif"
      }
    },
    {
      "name": "1. Products API",
      "item": [
        {
          "name": "Get Daftar Kategori Unik",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "categories"]
            }
          }
        },
        {
          "name": "Get Semua Produk",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products",
              "host": ["{{base_url}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "Filter Produk by Kategori",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products?category=Elektronik",
              "host": ["{{base_url}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "category", "value": "Elektronik" }
              ]
            }
          }
        },
        {
          "name": "Cari Produk (Search)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products?search=Kemeja",
              "host": ["{{base_url}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "search", "value": "Kemeja" }
              ]
            }
          }
        },
        {
          "name": "Get Detail Produk by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products/1",
              "host": ["{{base_url}}"],
              "path": ["api", "products", "1"]
            }
          }
        },
        {
          "name": "Create Produk Baru (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Produk Tes UTS Baru\",\n  \"price\": 150000,\n  \"category\": \"Fashion Pria\",\n  \"image\": \"https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=400\",\n  \"description\": \"Produk percobaan untuk pengujian API UTS.\",\n  \"stock\": 25,\n  \"rating\": 4.9\n}"
            },
            "url": {
